{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=DocsValidator;Trusted_Connection=true;TrustServerCertificate=true;"
  },
  "Jwt": {
    "SecretKey": "your-super-secret-key-change-this-in-production-make-it-at-least-32-characters-long!",
    "Issuer": "DocsValidator",
    "Audience": "DocsValidatorApi",
    "ExpiryHours": 24
  },
  "Cors": {
    "AllowedOrigins": [ "https://yourdomain.com" ]
  },
  "FileStorage": {
    "Path": "./storage"
  },
  "ClamAV": {
    "Url": "http://localhost:3310"
  },
  "Email": {
    "Provider": "Smtp",
    "Smtp": {
      "Host": "smtp.gmail.com",
      "Port": 587,
      "UseTls": true,
      "Username": "your-email@gmail.com",
      "Password": "your-app-password",
      "FromAddress": "noreply@yourdomain.com",
      "FromName": "Docs Validator"
    },
    "Retries": 3,
    "RetryDelaySeconds": 60,
    "TimeoutSeconds": 30
  },
  "Notifications": {
    "EnableBackgroundProcessing": true,
    "BatchSize": 10,
    "PollingIntervalSeconds": 30,
    "RetentionDays": 90
  }
}
